Options -Indexes

# Negar acesso direto a arquivos de dados
<FilesMatch "\.json(\.lock)?$">
    Require all denied
</FilesMatch>

# O dashboard antigo foi removido, mas o check-in e save.php são essenciais para o funcionamento público
<FilesMatch "^(area|checkin|save|worker)\.php$">
    Require all granted
</FilesMatch>
